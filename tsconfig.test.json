{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "outDir": ".test-dist",
    "rootDir": ".",
    "noEmit": false,
    "incremental": false,
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": [
    "src/lib/ai/error-policy.ts",
    "src/lib/server/research-cost-control.ts",
    "tests/**/*.test.ts"
  ]
}
