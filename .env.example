# Generate a unique random value for each environment
AUTH_SECRET=

# Google Cloud Console OAuth 2.0 credentials
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Comma-separated Google accounts that may use the production app
AUTH_ALLOWED_EMAILS=

# AI provider API keys
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Optional model overrides
OPENAI_MODEL=gpt-5.5
ANTHROPIC_MODEL=claude-sonnet-4-6
GEMINI_MODEL=gemini-3.5-flash
