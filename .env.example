# Generate a unique random value for each environment
AUTH_SECRET=

# Google Cloud Console OAuth 2.0 credentials
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Comma-separated Google accounts that may use the production app
AUTH_ALLOWED_EMAILS=

# AI provider API keys
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Optional model overrides
OPENAI_MODEL=gpt-5.5
ANTHROPIC_MODEL=claude-sonnet-4-6
GEMINI_MODEL=gemini-3.5-flash

# Optional cost controls
AI_MAX_OUTPUT_TOKENS=4000
RESEARCH_MAX_RUNS_PER_HOUR=6
RESEARCH_COOLDOWN_SECONDS=30

# Google Drive save via Apps Script
GOOGLE_DRIVE_GAS_WEB_APP_URL=
GOOGLE_DRIVE_GAS_SHARED_SECRET=

# GitHub Markdown save
GITHUB_REPORT_TOKEN=
GITHUB_REPORT_OWNER=hiroshiandailab
GITHUB_REPORT_REPO=3ai-research-and-report
GITHUB_REPORT_BRANCH=main
GITHUB_REPORT_DIR=reports
